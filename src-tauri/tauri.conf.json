{
  "$schema": "https://raw.githubusercontent.com/nicegui/tauri-apps__tauri/tauri-v2/tooling/cli/schema.json",
  "productName": "Claude Desktop",
  "version": "0.9.3",
  "identifier": "com.claude-desktop.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Claude Code Desktop",
        "width": 1000,
        "height": 700,
        "minWidth": 600,
        "minHeight": 400,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": null,
      "signingIdentity": null,
      "minimumSystemVersion": "10.13"
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/shehuiyao/claudedesktop/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJGMkUzMDAwMkVBNjMyM0IKUldRN01xWXVBREF1djZ5VU5CaXM2Sk5ZOGQ0Q3pJVE02L0pLckd2Skp0Nk1BNktzemNldWE0Nm8K"
    }
  }
}
